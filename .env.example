# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Anthropic API key - powers the vision extraction and localization agents
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Twilio credentials - powers real WhatsApp/SMS delivery (optional for demo)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1XXXXXXXXXX

# Fernet key used to encrypt patient data at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEDSAATHI_ENCRYPTION_KEY=your_generated_fernet_key_here
